# Branding values are read at frontend build time.
# Set these before `npm run build` or before building the frontend Docker image.
# Changing nginx container runtime env alone will not update the already-built HTML metadata.
VITE_APP_NAME=Clawith
VITE_APP_DESCRIPTION=Clawith — 企业数字员工平台
VITE_APP_LOGO_LIGHT=/logo-black.png
VITE_APP_LOGO_DARK=/logo-white.png
